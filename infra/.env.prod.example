# ─── 운영 환경 변수 (infra/.env.prod) ────────────────────────────────────────
# 이 파일을 복사하여 infra/.env.prod 를 생성하고 실제 값으로 채우세요.
# .env.prod 는 .gitignore에 포함되어 있습니다 (절대 커밋하지 마세요).

# ─── GitHub Container Registry (GHCR) ─────────────
GHCR_USERNAME=YOUR_GITHUB_USERNAME
GHCR_REPO=YOUR_GITHUB_REPO_NAME


# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=ams_db
POSTGRES_USER=ams
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── Backend ─────────────────────────────────────────────────────────────────
# PostgreSQL 연결 URL (db 서비스 컨테이너 이름 사용)
DATABASE_URL=postgresql+asyncpg://ams:CHANGE_THIS_STRONG_PASSWORD@db:5432/ams_db

# JWT 시크릿 키 (운영: 최소 64자 이상 랜덤 문자열)
SECRET_KEY=9f2c8e4b1a3d6f7890c2d4e5b678a1230ef456789abcdef012345678901234ab

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# 프론트엔드 CORS 허용 URL (NAS IP 또는 도메인)
FRONTEND_URL=http://192.168.0.22

# ─── Dell API (미사용 — 수기 등록 방식) ─────────────────────────────────────
DELL_API_CLIENT_ID=
DELL_API_CLIENT_SECRET=
